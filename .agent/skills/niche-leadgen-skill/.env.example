# ─── Niche LeadGen Skill — ENV šablóna ───────────────────────────────────────
# Kópia tohto súboru: cp .env.example .env
# Potom vyplň hodnoty nižšie. Nikdy necommituj .env do gitu!

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/automation

# Smartlead API kľúč
# Nájdeš ho v Smartlead → Settings → API
SMARTLEAD_API_KEY=

# Google Maps API kľúč (pre Places API)
# Nájdeš ho v Google Cloud Console → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=

# Serper.dev API kľúč (serper.dev → Dashboard → API Key)
SERPER_API_KEY=

# ─── Voliteľné ────────────────────────────────────────────────────────────────

# Slack Webhook URL (pre notifikácie po dokončení pipeline)
# Slack → App → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# ─── AI generovanie obsahu ────────────────────────────────────────────────────
# Icebreakery a email sekvencie generuje priamo Claude Code — žiadny API kľúč nie je potrebný!
# Workflow: prep-for-ai.ts → Claude vygeneruje → write-icebreakers.ts
#
# (Voliteľné) Ak chceš samostatné API volania mimo Claude Code:
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
